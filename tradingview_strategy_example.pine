//@version=5
strategy("黄金交易策略示例", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=1000, commission_type=strategy.commission.percent, commission_value=0.1)

// === 策略参数 ===
length = input.int(20, title="移动平均周期")
rsi_length = input.int(14, title="RSI 周期")
rsi_overbought = input.int(70, title="RSI 超买")
rsi_oversold = input.int(30, title="RSI 超卖")

// === 计算指标 ===
sma = ta.sma(close, length)
rsi = ta.rsi(close, rsi_length)

// === 绘制指标 ===
plot(sma, color=color.blue, title="SMA")
hline(rsi_overbought, "超买", color=color.red)
hline(rsi_oversold, "超卖", color=color.green)

// === 交易条件 ===
longCondition = ta.crossover(close, sma) and rsi < rsi_oversold
shortCondition = ta.crossunder(close, sma) and rsi > rsi_overbought

// === 执行交易 ===
if (longCondition)
    strategy.entry("Buy", strategy.long)

if (shortCondition)
    strategy.entry("Sell", strategy.short)

// === 警报消息 ===
webhook_message = '{"strategy": "gold_sma_rsi", "action": "{{strategy.order.action}}", "symbol": "XAUUSD", "lot": 0.1, "sl_points": 50, "tp_points": 100}'

// 警报配置：
// 1. 创建警报时选择此策略
// 2. 设置 Webhook URL 为你的服务器地址
// 3. 消息内容选择 "Alert message" 并填入上面的 JSON
